{
  "name": "thewall",
  "version": "1.0.0",
  "description": "TheWall image slideshow application",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "dev": "wrangler dev --port 8788",
    "dev:node": "node --watch --env-file=.dev.vars server.js",
    "start": "node server.js",
    "deploy": "wrangler deploy",
    "test": "playwright test"
  },
  "dependencies": {
    "@fastify/static": "^6.12.0",
    "fastify": "^4.24.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.10.0",
    "wrangler": "^3.114.0"
  }
}
